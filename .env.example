# Local-dev .env. The platform deploy reads everything it needs from
# ~/Developer/WebsiteData/.env via app.yaml — this file is just for `npm run dev`.

# MySQL (local-dev). Either MYSQL_* (preferred) or DB_* are accepted.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=movies
MYSQL_PASSWORD=movies
MYSQL_DATABASE=movies

# Server
PORT=4000
SESSION_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# Movie metadata APIs (free):
#   TMDB:  https://www.themoviedb.org/settings/api
#   OMDB:  https://www.omdbapi.com/apikey.aspx
TMDB_API_KEY=
OMDB_API_KEY=

# --- Platform deploy only (set in ~/Developer/WebsiteData/.env, not here) ---
# APP_MYSQL_PASSWORD=
# MOVIES_SESSION_SECRET=
# MOVIES_CORS_ORIGIN=https://movies.danj.co
